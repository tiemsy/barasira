APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080 # https://barasira.com

SUPERADMIN_EMAIL=superadmin@barasira.com
SUPERADMIN_PASSWORD=
SUPERADMIN_PHONE=+22370000000
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin

# Optional paths used by the superadmin system log viewer.
# LOG_VIEWER_PHP_PATH=/var/www/html/storage/logs/php-error.log
# LOG_VIEWER_CONFIGURE_PHP_LOGGING=true
# LOG_VIEWER_NGINX_ACCESS_PATH=/var/log/nginx/access.log
# LOG_VIEWER_NGINX_ERROR_PATH=/var/log/nginx/error.log

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null

CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CURRENCY=EUR
PAYPAL_XOF_PER_UNIT=
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=barasira_db
DB_PORT=3306
DB_DATABASE=barasira
DB_USERNAME=barasira
DB_PASSWORD=barasira

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=barasira_mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@barasira.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_HMR_HOST=127.0.0.1
VITE_API_URL="${APP_URL}"
VITE_APP_NAME="${APP_NAME}"
VITE_GOOGLE_MAPS_API_KEY=
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

L5_SWAGGER_CONST_HOST="${APP_URL}"
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_GENERATE_YAML_COPY=true
L5_SWAGGER_UI_DARK_MODE=false

# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

VITE_APP_URL="${APP_URL}"
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_HMR_HOST=

SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:5173,127.0.0.1:8080,127.0.0.1:5173
SESSION_DOMAIN=localhost
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_LIFETIME=120

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
