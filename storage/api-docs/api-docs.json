{
    "openapi": "3.0.0",
    "info": {
        "title": "Bara Sira API",
        "description": "Documentation complète de l'API de Bara Sira savec Swagger",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://my-default-host.com",
            "description": "Serveur principal"
        }
    ],
    "paths": {
        "/api/users": {
            "get": {
                "tags": [
                    "Users"
                ],
                "summary": "Liste des utilisateurs",
                "operationId": "566aed8efb436ca506e0ef51a032ecd9",
                "responses": {
                    "200": {
                        "description": "Liste des utilisateurs",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/User"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Users"
                ],
                "summary": "Créer un utilisateur",
                "operationId": "be551c1d694a01c164966f58bfa77013",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email"
                                ],
                                "properties": {
                                    "first_name": {
                                        "type": "string",
                                        "example": "Jean"
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Dupont"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "jean@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "******"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "0022374321256"
                                    },
                                    "role": {
                                        "type": "enum",
                                        "example": "['client', 'prestataire', 'admin'], Defauft:client"
                                    },
                                    "bio": {
                                        "type": "text",
                                        "example": "Biography"
                                    },
                                    "avatar_url": {
                                        "type": "string",
                                        "example": "/storage/john/doe/jeandupont.jpg"
                                    },
                                    "rating": {
                                        "type": "decimal",
                                        "example": "100.00"
                                    },
                                    "verified": {
                                        "type": "boolean",
                                        "example": "true"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Utilisateur créé",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/{id}": {
            "get": {
                "tags": [
                    "Users"
                ],
                "summary": "Obtenir un utilisateur par ID",
                "operationId": "6f51bd5fa2dddcd25e44cfa53dcbd10a",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Utilisateur trouvé",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Utilisateur introuvable"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "title": "User",
                "required": [
                    "id",
                    "name",
                    "email"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "email": {
                        "type": "string",
                        "example": "john@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "******"
                    },
                    "phone": {
                        "type": "string",
                        "example": "0022374321256"
                    },
                    "role": {
                        "type": "enum",
                        "example": "['client', 'prestataire', 'admin'], Defauft:client"
                    },
                    "bio": {
                        "type": "text",
                        "example": "Biography"
                    },
                    "avatar_url": {
                        "type": "string",
                        "example": "/storage/john/doe/johndoe.jpg"
                    },
                    "rating": {
                        "type": "decimal",
                        "example": "100.00"
                    },
                    "verified": {
                        "type": "boolean",
                        "example": "true"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Users",
            "description": "Users"
        }
    ]
}